{
  "name": "hmk-drawing-overlay",
  "productName": "HMK Drawing Overlay",
  "version": "1.0.0",
  "description": "HMK Construction Drawing Overlay Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build-zip": "electron-builder --mac zip"
  },
  "build": {
    "appId": "com.hmkco.drawing-overlay",
    "productName": "HMK Drawing Overlay",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "HMK Drawing Overlay",
      "icon": "assets/icon.icns",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 180, "type": "file" },
        { "x": 400, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
